# ─────────────────────────────────────────────────────────────
# Шаблон переменных окружения relok-store.
# Скопируй в .env и заполни реальными значениями:
#   cp .env.example .env
# Запуск с этим файлом:
#   node --env-file=.env server/server.js
# (или через systemd: EnvironmentFile=/path/to/relok-store/.env)
# .env коммитить НЕЛЬЗЯ — он уже в .gitignore.
# ─────────────────────────────────────────────────────────────

# Порт HTTP-сервера (по умолчанию 3000)
PORT=3000

# Токен админ-панели (/admin). Поставь длинный случайный — НЕ logovo-admin.
ADMIN_TOKEN=

# Публичный https-адрес магазина (без слэша в конце).
# Нужен для return_url ЮKassa и корректных ссылок за прокси.
PUBLIC_URL=https://your-domain.example

# ── Выбор платёжного провайдера ─────────────────────────────
# robokassa (по умолчанию) | yookassa
PAYMENT_PROVIDER=robokassa
# Интервал поллинга статуса оплат, мс (по умолчанию 20000). Опционально.
PAYMENT_POLL_INTERVAL_MS=20000

# ── ЮKassa (если PAYMENT_PROVIDER=yookassa) ─────────────────
# ЛК ЮKassa → Настройки магазина (shopId) и Интеграция → Секретный ключ
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ── Robokassa (если PAYMENT_PROVIDER=robokassa) ─────────────
# ЛК Robokassa → Технические настройки. Статус узнаём поллингом (OpStateExt),
# вебхук (ResultURL) не используется. Пароль#2 нужен для запроса статуса.
ROBOKASSA_MERCHANT_LOGIN=
ROBOKASSA_PASSWORD1=
ROBOKASSA_PASSWORD2=
# Алгоритм хеша подписи — ДОЛЖЕН совпадать с настройкой в ЛК: md5|sha1|sha256|sha512
ROBOKASSA_HASH_ALGO=md5
# Тестовый режим: 1 → платежи тестовые (используй тестовые пароли из ЛК).
ROBOKASSA_IS_TEST=0
# Фискализация (54-ФЗ). 1 → в платёж добавляется Receipt (нужно, если в ЛК
# Robokassa включена фискализация). Параметры чека ниже.
ROBOKASSA_FISCAL=1
# Система налогообложения: osn|usn_income|usn_income_outcome|... (пусто → из ЛК).
ROBOKASSA_SNO=
# Ставка НДС позиции: none|vat0|vat10|vat20|...
ROBOKASSA_TAX=none
# Признак способа/предмета расчёта чека.
ROBOKASSA_PAYMENT_METHOD=full_payment
ROBOKASSA_PAYMENT_OBJECT=service
# E-mail для чека (в подпись не входит). Пусто → Robokassa спросит на форме.
ROBOKASSA_EMAIL=

# ── Telegram-уведомления (опционально) ──────────────────────
BOT_TOKEN=
NOTIFY_CHAT_ID=

# ── Синхронизатор цен PS Store (TR) → Google Sheets ─────────
# (инструмент tools/ps-price-sync — запуск: npm run sync)
# Путь к JSON-ключу сервисного аккаунта Google.
GOOGLE_APPLICATION_CREDENTIALS=tools/ps-price-sync/google-credentials.json
# ID существующей Google-таблицы. Пусто → таблица создастся автоматически.
GOOGLE_SHEET_ID=
# Имя листа внутри книги.
GOOGLE_SHEET_TAB=Цены PS Store TR
# E-mail вашего личного Google-аккаунта — ему выдастся доступ к новой таблице.
GOOGLE_SHARE_EMAIL=
# Тонкая настройка (опционально): паузы/повторы/порог совпадения.
PS_THROTTLE_MS=800
PS_RETRIES=3
MATCH_MIN_SCORE=0.55

# ── Авто-выдача кодов пополнения (PSN Turkey) ───────────────
# Источник цены в лирах: та же Google-таблица (GOOGLE_SHEET_ID выше).
# Время кэша карты цен из таблицы, мс (по умолчанию 5 минут).
TRY_SHEET_TTL_MS=300000
# Логи сервисов выдачи кодов: уровень и (опц.) каталог для файла.
CODES_LOG_LEVEL=info
# CODES_LOG_DIR=server/logs
